---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';

const sortedProjects = [...projects].sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout title="Projects | Felix Douaud">
  <main class="shell projects-page">
    <header class="topbar fade-up">
      <a class="brand" href="/">Process</a>
      <nav>
        <a href="/" data-i18n="navHome">Home</a>
        <span>/</span>
        <a class="is-active" href="/projects" data-i18n="navProjects">Projects</a>
      </nav>
    </header>

    <div class="layout">
      <aside class="sidebar">
        <section class="card fade-up">
          <h2 class="mini-title section-heading">
            <svg class="icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 19h16M7 16V9m5 7V5m5 11v-4"></path>
            </svg>
            <span data-i18n="statsTitle">Stats</span>
          </h2>
          <p class="stat-number">{sortedProjects.length}</p>
          <p class="stat-label" data-i18n="statsLabel">Projects</p>
        </section>

        <section class="card fade-up">
          <h2 class="mini-title section-heading">
            <svg class="icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M12 10v6M12 7h.01"></path>
            </svg>
            <span data-i18n="infoTitle">Info</span>
          </h2>
          <div class="link-list">
            <a class="link-with-icon" href="https://github.com/Processssss" target="_blank" rel="noreferrer">
              <svg class="icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M9 18c-4 1.2-4-2-6-2m12 4v-3.1a2.7 2.7 0 0 0-.8-2.1c2.6-.3 5.3-1.3 5.3-5.8a4.5 4.5 0 0 0-1.2-3.2 4.2 4.2 0 0 0-.1-3.1s-1-.3-3.2 1.2a11 11 0 0 0-6 0C6.8 2.4 5.8 2.7 5.8 2.7a4.2 4.2 0 0 0-.1 3.1A4.5 4.5 0 0 0 4.5 9c0 4.5 2.7 5.5 5.3 5.8a2.7 2.7 0 0 0-.8 2.1V20"></path>
              </svg>
              <span data-i18n="githubLabel">GitHub</span>
            </a>
          </div>
        </section>

        <section class="card fade-up">
          <h2 class="mini-title section-heading">
            <svg class="icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 7h18M3 12h18M3 17h18"></path>
              <path d="M7 7a14 14 0 0 0 0 10M17 7a14 14 0 0 1 0 10"></path>
            </svg>
            <span data-i18n="languageTitle">Language</span>
          </h2>
          <div class="lang-switch" role="group" aria-label="Language switch">
            <button type="button" class="lang-btn" data-lang-switch="en">EN</button>
            <button type="button" class="lang-btn" data-lang-switch="fr">FR</button>
          </div>
        </section>
      </aside>

      <section class="card content fade-up">
        <h2 class="section-heading">
          <svg class="icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="6" width="18" height="12" rx="2"></rect>
            <path d="M9 6v12M9 12h1.5m4 0h1.5"></path>
          </svg>
          <span data-i18n="projectsTitle">Projects</span>
        </h2>
        <div class="item-list">
          {sortedProjects.map((project, index) => (
            <article class="item" style={`animation-delay: ${index * 80}ms`}>
              <div class="item-head">
                <h3>
                  <a class="title-link" href={`/projects/${project.slug}`}>{project.name}</a>
                </h3>
                <span>{new Date(project.date).toLocaleDateString('en-US')}</span>
              </div>
              <p data-i18n-dual data-en={project.summary} data-fr={project.summaryFr}>{project.summary}</p>
            </article>
          ))}
        </div>
      </section>
    </div>
  </main>
  <script is:inline>
    (() => {
      const PROJECTS_I18N = {
        en: {
          navHome: 'Home',
          navProjects: 'Projects',
          statsTitle: 'Stats',
          statsLabel: 'Projects',
          infoTitle: 'Info',
          githubLabel: 'GitHub',
          languageTitle: 'Language',
          projectsTitle: 'Projects'
        },
        fr: {
          navHome: 'Accueil',
          navProjects: 'Projets',
          statsTitle: 'Statistiques',
          statsLabel: 'Projets',
          infoTitle: 'Informations',
          githubLabel: 'GitHub',
          languageTitle: 'Langue',
          projectsTitle: 'Projets'
        }
      };

      const getSavedLang = () => {
        try {
          const stored = localStorage.getItem('site-lang');
          if (stored === 'fr' || stored === 'en') return stored;
        } catch {}
        return document.documentElement.lang === 'fr' ? 'fr' : 'en';
      };

      const applyLanguage = (lang) => {
        const dict = PROJECTS_I18N[lang] ?? PROJECTS_I18N.en;
        document.querySelectorAll('[data-i18n]').forEach((node) => {
          const key = node.getAttribute('data-i18n');
          if (!key || !dict[key]) return;
          node.textContent = dict[key];
        });
        document.querySelectorAll('[data-i18n-dual]').forEach((node) => {
          const text = node.getAttribute(`data-${lang}`);
          if (text) node.textContent = text;
        });
      };

      applyLanguage(getSavedLang());
      document.querySelectorAll('[data-lang-switch]').forEach((button) => {
        button.addEventListener('click', () => {
          const lang = button.getAttribute('data-lang-switch');
          if (lang === 'fr' || lang === 'en') applyLanguage(lang);
        });
      });
    })();
  </script>
</BaseLayout>
